generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  avatarPath   String?   @map("avatar_path")
  phone        String?
  birthDate    DateTime? @map("birth_date") @db.Date
  salary       Decimal?  @db.Decimal(12, 2)
  lastSeenAt   DateTime? @map("last_seen_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userRoles           UserRole[]
  refreshTokens       RefreshToken[]
  sectionMembers      SectionMember[]
  organizationMembers OrganizationMember[]
  createdInvites      InviteToken[]
  auditLogs           AuditLog[]
  uploadedDocuments   OrganizationDocument[]
  workContacts        WorkContact[]
  knowledgeItems      KnowledgeItem[]
  createdTasks        Task[]               @relation("TaskCreator")
  taskAssignees       TaskAssignee[]
  taskComments        TaskComment[]        @relation("TaskCommentAuthor")
  telegramBinding      TelegramBinding?
  notifications        Notification[]
  passwordResetTokens  PasswordResetToken[]
  messageTemplates     MessageTemplate[]    @relation("MessageTemplateCreator")
  sentMessages         MessageLog[]         @relation("MessageLogSender")
  createdTickets       Ticket[]             @relation("TicketCreator")
  assignedTickets      Ticket[]             @relation("TicketAssignee")
  ticketMessages       TicketMessage[]      @relation("TicketMessageAuthor")
  createdAnnouncements Announcement[]       @relation("AnnouncementAuthor")
  announcementReads    AnnouncementRead[]
  filedReportEntries   ReportEntry[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  entity      String
  action      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@unique([entity, action])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  tokenHash String   @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum DocumentType {
  CONTRACT // Договор
  ACT      // Акт
  INVOICE  // Счёт
  REPORT   // Отчёт
  WAYBILL  // Накладная
  OTHER    // Прочее
}

enum TaxSystem {
  USN6
  USN15
  AUSN8
  AUSN20
  PSN
  OSNO
  USN_NDS5
  USN_NDS7
  USN_NDS22
}

enum DigitalSignatureStatus {
  NONE
  CLIENT
  US
  MCHD
}

enum ReportingChannel {
  KONTUR
  SBIS
  ASTRAL
  ONE_C
}

enum ServiceType {
  ZERO
  MINIMAL
  FULL
  HR
  REPORTING
  HR_REPORTING
  PARTIAL
}

enum OrgForm {
  OOO  // ООО
  IP   // ИП
  NKO  // НКО
  AO   // АО
  PAO  // ПАО
}

enum PaymentDestination {
  BANK_TOCHKA  // Банк (Точка)
  CARD         // Карта
  CASH         // Наличные
  UNKNOWN      // Неизвестно
}

enum PaymentFrequency {
  MONTHLY       // Ежемесячно
  QUARTERLY     // Ежеквартально
  SEMI_ANNUAL   // Раз в полгода
}

enum SystemAccessType {
  KASSA   // Касса
  ONE_C   // 1С
  OTHER   // Другое
}

model Section {
  id        String   @id @default(uuid())
  number    Int      @unique
  name      String?
  animal    String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       SectionMember[]
  organizations Organization[]

  @@map("sections")
}

model SectionMember {
  id        String @id @default(uuid())
  sectionId String @map("section_id")
  userId    String @map("user_id")
  role      String // accountant, auditor

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectionId, userId])
  @@index([userId])
  @@map("section_members")
}

model ClientGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organizations Organization[]

  @@map("client_groups")
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  inn           String?  @unique
  form          OrgForm?
  status        String   @default("active") // active, new, archived
  sectionId     String?  @map("section_id")
  clientGroupId String?  @map("client_group_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // --- Общая ---
  taxSystems      TaxSystem[]                    @map("tax_systems")
  employeeCount   Int?                           @map("employee_count")
  opsPerMonth     Int?                           @map("ops_per_month")
  hasCashRegister Boolean     @default(false)    @map("has_cash_register")

  // --- Юридическая ---
  ogrn         String?
  kpp          String?
  legalAddress String? @map("legal_address")

  // --- Реквизиты ---
  checkingAccount     String? @map("checking_account")
  bik                 String?
  correspondentAccount String? @map("correspondent_account")
  requisitesBank      String? @map("requisites_bank")

  // --- Прочее ---
  importantComment String? @map("important_comment")

  // --- Бухгалтерская ---
  digitalSignature       DigitalSignatureStatus? @map("digital_signature")
  digitalSignatureExpiry DateTime?               @map("digital_signature_expiry")
  reportingChannel       ReportingChannel?       @map("reporting_channel")
  serviceType            ServiceType?            @map("service_type")

  // --- Финансовая ---
  monthlyPayment         Decimal?            @db.Decimal(12, 2) @map("monthly_payment")
  previousMonthlyPayment Decimal?            @db.Decimal(12, 2) @map("previous_monthly_payment")
  priceChangeDate        DateTime?           @db.Date            @map("price_change_date")
  paymentDestination     PaymentDestination?                     @map("payment_destination")
  paymentFrequency       PaymentFrequency    @default(MONTHLY)   @map("payment_frequency")
  serviceStartDate       DateTime?           @db.Date            @map("service_start_date")
  debtAmount             Decimal?            @db.Decimal(12, 2)  @map("debt_amount")

  section           Section?             @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  clientGroup       ClientGroup?         @relation(fields: [clientGroupId], references: [id], onDelete: SetNull)
  members           OrganizationMember[]
  inviteTokens      InviteToken[]
  bankAccounts      OrganizationBankAccount[]
  systemAccesses    OrganizationSystemAccess[]
  contacts          OrganizationContact[]
  documents         OrganizationDocument[]
  tasks             Task[]
messageLogs       MessageLog[]
  tickets           Ticket[]
  reportEntries     ReportEntry[]
  bankTransactions  BankTransaction[]
  paymentPeriods    PaymentPeriod[]

  @@index([sectionId])
  @@index([clientGroupId])
  @@map("organizations")
}

model OrganizationMember {
  id             String @id @default(uuid())
  userId         String @map("user_id")
  organizationId String @map("organization_id")
  role           String @default("client") // client, responsible, etc.

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_members")
}

model InviteToken {
  id             String    @id @default(uuid())
  token          String    @unique
  organizationId String    @map("organization_id")
  createdById    String    @map("created_by_id")
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("invite_tokens")
}

model OrganizationBankAccount {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  bankName       String   @map("bank_name")
  accountNumber  String?  @map("account_number")
  login          String?
  password       String?
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_bank_accounts")
}

model OrganizationContact {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  contactPerson  String   @map("contact_person")
  phone          String?
  email          String?
  telegram       String?
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_contacts")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@index([entity])
  @@index([action])
  @@map("audit_logs")
}

model OrganizationDocument {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  type           DocumentType
  originalName   String       @map("original_name")
  storagePath    String       @map("storage_path")
  mimeType       String       @map("mime_type")
  size           Int
  comment        String?
  uploadedById   String       @map("uploaded_by_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  version        Int          @default(1)
  groupId        String       @default(dbgenerated("gen_random_uuid()")) @map("group_id") @db.Uuid
  isLatest       Boolean      @default(true) @map("is_latest")
  documentDate   DateTime?    @map("document_date") @db.Date
  periodMonth    Int?         @map("period_month") @db.SmallInt
  periodYear     Int?         @map("period_year") @db.SmallInt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("organization_documents")
}

enum KnowledgeItemType {
  ARTICLE
  VIDEO
  FILE
}

enum KnowledgeAudience {
  STAFF
  CLIENT
}

model KnowledgeItem {
  id           String              @id @default(uuid())
  title        String
  type         KnowledgeItemType
  audience     KnowledgeAudience
  tags         String[]
  description    String?
  content        String?
  url            String?
  coverImagePath String?           @map("cover_image_path")
  coverImageName String?           @map("cover_image_name")
  originalName   String?           @map("original_name")
  storagePath    String?           @map("storage_path")
  mimeType       String?           @map("mime_type")
  fileSize       Int?              @map("file_size")
  createdById  String              @map("created_by_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("knowledge_items")
}

model OrganizationSystemAccess {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  systemType     SystemAccessType @map("system_type")
  name           String?
  login          String?
  password       String?
  comment        String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_system_accesses")
}

model WorkContact {
  id          String   @id @default(uuid())
  name        String
  position    String?
  phone       String?
  comment     String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("work_contacts")
}

enum ExpenseType {
  RECURRING // постоянные (ежемесячные)
  ONE_TIME  // разовые
}

model RevenueSnapshot {
  id               String   @id @default(uuid())
  year             Int
  month            Int
  // Revenue
  totalRevenue     Decimal  @db.Decimal(12, 2) @map("total_revenue")
  orgCount         Int      @map("org_count")
  orgsWithPayment  Int      @default(0) @map("orgs_with_payment")
  avgCheck         Decimal  @db.Decimal(12, 2) @map("avg_check")
  // Payroll
  payrollTotal     Decimal  @default(0) @db.Decimal(12, 2) @map("payroll_total")
  staffCount       Int      @default(0) @map("staff_count")
  // Expenses & Income
  recurringExpenses Decimal @default(0) @db.Decimal(12, 2) @map("recurring_expenses")
  oneTimeExpenses  Decimal  @default(0) @db.Decimal(12, 2) @map("one_time_expenses")
  incomeTotal      Decimal  @default(0) @db.Decimal(12, 2) @map("income_total")
  // Profit
  grossProfit      Decimal  @default(0) @db.Decimal(12, 2) @map("gross_profit")
  margin           Decimal  @default(0) @db.Decimal(8, 4)
  // Debt & Clients
  debtTotal        Decimal  @default(0) @db.Decimal(12, 2) @map("debt_total")
  clientsActive    Int      @default(0) @map("clients_active")
  clientsNew       Int      @default(0) @map("clients_new")

  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([year, month])
  @@map("revenue_snapshots")
}

model Expense {
  id          String      @id @default(uuid())
  name        String
  amount      Decimal     @db.Decimal(12, 2)
  type        ExpenseType
  date        DateTime?
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("expenses")
}

model Income {
  id          String   @id @default(uuid())
  name        String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("incomes")
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskCategory {
  REPORTING
  DOCUMENTS
  PAYMENT
  OTHER
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Task {
  id                 String          @id @default(uuid())
  title              String
  description        String?
  status             TaskStatus      @default(OPEN)
  priority           TaskPriority    @default(MEDIUM)
  category           TaskCategory    @default(OTHER)
  dueDate            DateTime?       @map("due_date")
  recurrenceType     RecurrenceType? @map("recurrence_type")
  recurrenceInterval Int             @default(1) @map("recurrence_interval")
  reminderSentAt     DateTime?       @map("reminder_sent_at")
  escalatedAt        DateTime?       @map("escalated_at")
  archivedAt         DateTime?       @map("archived_at")
  groupId            String?         @map("group_id")
  organizationId     String?         @map("organization_id")
  reportTypeId       String?         @map("report_type_id")
  reportYear         Int?            @map("report_year")
  reportPeriod       Int?            @map("report_period")
  reportSectionId    String          @default("") @map("report_section_id")
  createdById        String          @map("created_by_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  organization    Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  reportType      ReportType?         @relation(fields: [reportTypeId], references: [id], onDelete: SetNull)
  createdBy       User                @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignees       TaskAssignee[]
  comments        TaskComment[]
  checklistItems  TaskChecklistItem[]

  @@unique([reportTypeId, reportYear, reportPeriod, reportSectionId])
  @@index([organizationId])
  @@index([dueDate])
  @@index([groupId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  authorId  String   @map("author_id")
  text      String

  createdAt DateTime @default(now()) @map("created_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

model TaskChecklistItem {
  id             String    @id @default(uuid())
  taskId         String    @map("task_id")
  text           String
  done           Boolean   @default(false)
  position       Int       @default(0)
  dueDate        DateTime? @map("due_date") @db.Date
  reportEntryId  String?   @unique @map("report_entry_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reportEntry ReportEntry? @relation(fields: [reportEntryId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@map("task_checklist_items")
}

model TaskAssignee {
  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_assignees")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    // "task_assigned" | "deadline_soon"
  title     String
  body      String?
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model TelegramBinding {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  chatId        String?   @unique @map("chat_id")
  username      String?
  code          String?   @unique
  codeExpiresAt DateTime? @map("code_expires_at")
  connectedAt   DateTime? @map("connected_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_bindings")
}

enum MessageChannel {
  EMAIL
  TELEGRAM
}

model MessageTemplate {
  id          String         @id @default(uuid())
  name        String
  subject     String?
  body        String
  channel     MessageChannel @default(EMAIL)
  createdById String         @map("created_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  createdBy User         @relation("MessageTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  messages  MessageLog[]

  @@map("message_templates")
}

model MessageLog {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  templateId     String?        @map("template_id")
  channel        MessageChannel
  recipient      String
  subject        String?
  body           String
  sentById       String         @map("sent_by_id")
  status         String         @default("sent")
  errorMessage   String?        @map("error_message")
  createdAt      DateTime       @default(now()) @map("created_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sentBy       User             @relation("MessageLogSender", fields: [sentById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
  @@map("message_logs")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ==================== Ticket System ====================

enum TicketType {
  QUESTION
  DOCUMENT_REQUEST
  PROBLEM
  DOCUMENT_UPLOAD
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING_CLIENT
  ON_HOLD
  ESCALATED
  CLOSED
  REOPENED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Ticket {
  id             String         @id @default(uuid())
  number         Int            @unique @default(autoincrement())
  subject        String
  type           TicketType     @default(QUESTION)
  status         TicketStatus   @default(NEW)
  priority       TicketPriority @default(NORMAL)

  organizationId String         @map("organization_id")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById    String         @map("created_by_id")
  createdBy      User           @relation("TicketCreator", fields: [createdById], references: [id])

  assignedToId   String?        @map("assigned_to_id")
  assignedTo     User?          @relation("TicketAssignee", fields: [assignedToId], references: [id])

  closedAt       DateTime?      @map("closed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  messages       TicketMessage[]

  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id         String    @id @default(uuid())
  body       String
  isInternal Boolean   @default(false) @map("is_internal")
  deletedAt  DateTime? @map("deleted_at")

  ticketId   String    @map("ticket_id")
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId   String    @map("author_id")
  author     User      @relation("TicketMessageAuthor", fields: [authorId], references: [id])

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  attachments TicketAttachment[]

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id        String   @id @default(uuid())
  fileName  String   @map("file_name")
  fileKey   String   @map("file_key")
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type")

  messageId String   @map("message_id")
  message   TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("ticket_attachments")
}

enum AnnouncementType {
  FEATURE
  FIX
  CHANGE
  REMOVAL
}

enum AnnouncementAudience {
  STAFF
  CLIENT
}

model Announcement {
  id          String                @id @default(uuid())
  title       String
  body        String
  type        AnnouncementType      @default(FEATURE)
  audience    AnnouncementAudience  @default(STAFF)
  publishedAt DateTime              @default(now()) @map("published_at")
  authorId    String                @map("author_id")
  author      User                  @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  reads       AnnouncementRead[]
  createdAt   DateTime              @default(now()) @map("created_at")

  @@map("announcements")
}

model AnnouncementRead {
  announcementId String       @map("announcement_id")
  userId         String       @map("user_id")
  readAt         DateTime     @default(now()) @map("read_at")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@map("announcement_reads")
}

// ==================== Reporting Tracker ====================

enum ReportFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ReportEntryStatus {
  NOT_SUBMITTED
  SUBMITTED
  ACCEPTED
  REJECTED
  NOT_APPLICABLE
}

model ReportType {
  id                  String          @id @default(uuid())
  name                String
  code                String          @unique
  description         String?
  frequency           ReportFrequency
  order               Int             @default(0)
  isActive            Boolean         @default(true) @map("is_active")
  deadlineDay         Int             @default(25) @map("deadline_day")
  deadlineMonthOffset Int             @default(1) @map("deadline_month_offset")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  entries ReportEntry[]
  tasks   Task[]

  @@map("report_types")
}

model ReportEntry {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  reportTypeId   String            @map("report_type_id")
  year           Int
  period         Int               // month (1-12) for MONTHLY, quarter (1-4) for QUARTERLY, 0 for YEARLY
  status         ReportEntryStatus @default(NOT_SUBMITTED)
  filedAt        DateTime?         @map("filed_at") @db.Date
  taxAmount      Decimal?          @db.Decimal(12, 2) @map("tax_amount")
  comment        String?
  filedById      String?           @map("filed_by_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportType    ReportType         @relation(fields: [reportTypeId], references: [id], onDelete: Cascade)
  filedBy       User?              @relation(fields: [filedById], references: [id], onDelete: SetNull)
  checklistItem TaskChecklistItem?

  @@unique([organizationId, reportTypeId, year, period])
  @@index([organizationId])
  @@index([reportTypeId])
  @@index([year, period])
  @@map("report_entries")
}

// ─── Bank Integration ────────────────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(uuid())
  bankName      String   @map("bank_name") // "tochka"
  accountNumber String   @unique @map("account_number")
  accessToken   String?  @map("access_token")
  refreshToken  String?  @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  isActive      Boolean  @default(true) @map("is_active")
  lastSyncAt    DateTime? @map("last_sync_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  transactions BankTransaction[]

  @@map("bank_accounts")
}

model BankTransaction {
  id              String    @id @default(uuid())
  bankAccountId   String    @map("bank_account_id")
  externalId      String    @unique @map("external_id") // ID from bank API
  date            DateTime
  amount          Decimal   @db.Decimal(12, 2)
  payerName       String?   @map("payer_name")
  payerInn        String?   @map("payer_inn")
  payerAccount    String?   @map("payer_account")
  purpose         String?   // назначение платежа
  organizationId  String?   @map("organization_id")
  matchStatus     TransactionMatchStatus @default(UNMATCHED) @map("match_status")
  matchedAt       DateTime? @map("matched_at")
  matchedBy       String?   @map("matched_by") // "auto" or userId
  createdAt       DateTime  @default(now()) @map("created_at")

  bankAccount  BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([bankAccountId, date])
  @@index([organizationId])
  @@index([payerInn])
  @@index([matchStatus])
  @@map("bank_transactions")
}

enum TransactionMatchStatus {
  UNMATCHED  // не сопоставлен
  AUTO       // автоматически по ИНН/названию
  MANUAL     // вручную привязан
  IGNORED    // игнорировать (не от клиента)
}

model PaymentPeriod {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  year           Int
  month          Int
  expected       Decimal             @db.Decimal(12, 2) // monthlyPayment на момент расчёта
  received       Decimal             @default(0) @db.Decimal(12, 2)
  status         PaymentPeriodStatus @default(PENDING)
  debtAmount     Decimal             @default(0) @db.Decimal(12, 2) @map("debt_amount")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, year, month])
  @@index([year, month])
  @@index([status])
  @@map("payment_periods")
}

enum PaymentPeriodStatus {
  PENDING   // ещё не наступил дедлайн
  PAID      // оплачено полностью
  PARTIAL   // частично оплачено
  OVERDUE   // просрочено (>15 дней)
}
