# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asbuh_portal

# Auth
JWT_SECRET=change_me_in_production
REFRESH_TOKEN_SECRET=change_me_in_production

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# Telegram Bot (optional — notifications disabled if not set)
# 1. Create a bot via @BotFather in Telegram
# 2. Copy the token here
TELEGRAM_BOT_TOKEN=

# App URL (used in password reset emails)
APP_URL=http://localhost:5173

# SMTP (optional — reset links printed to console if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@asbuh.local

# Proxy for Telegram API (if Telegram is blocked in your network)
# Examples: http://user:pass@proxy-host:3128  or  socks5://127.0.0.1:1080
HTTPS_PROXY=
